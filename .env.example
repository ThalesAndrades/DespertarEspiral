# ──────────────────────────────────────────────────────────────
# Variáveis expostas ao cliente (build Vite)
# ──────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ──────────────────────────────────────────────────────────────
# Segredos das Edge Functions (configurar em:
# Supabase Dashboard → Project Settings → Functions → Secrets)
# ──────────────────────────────────────────────────────────────
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Asaas (gateway de pagamento)
# ASAAS_API_KEY=
# ASAAS_WEBHOOK_TOKEN=

# Sequenzy (email marketing + transacional)
# SEQUENZY_API_KEY=

# CORS + URLs públicas
# ALLOWED_ORIGINS=https://despertarespiral.com,https://www.despertarespiral.com
# PUBLIC_SITE_URL=https://despertarespiral.com
