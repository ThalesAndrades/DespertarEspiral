# =============================================================================
# Despertar Espiral - variáveis de ambiente
# =============================================================================
#
# IMPORTANTE: nunca comite .env real. Apenas este .env.example.
# Em produção, definir como GitHub Secrets (workflow de deploy injeta no build).
#
# -----------------------------------------------------------------------------
# Frontend - lidas no momento do build pelo Vite.
# Toda var pública do Vite precisa ter prefixo VITE_.
# -----------------------------------------------------------------------------

# Backend OnSpace (auth via Google + email OTP, banco de dados, storage, edge functions).
# Pegue em: OnSpace Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Edge Functions (configurar no OnSpace/Supabase Dashboard -> Functions -> Secrets;
# NUNCA expor estas no frontend).
# -----------------------------------------------------------------------------
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# ASAAS_API_KEY=
# ASAAS_WEBHOOK_SECRET=
# SEQUENZY_API_KEY=
# ALLOWED_ORIGINS=https://despertarespiral.com,https://www.despertarespiral.com
# PUBLIC_SITE_URL=https://despertarespiral.com

# -----------------------------------------------------------------------------
# Deploy Hostinger via GitHub Actions (apenas referencial; valores reais ficam
# em Settings -> Secrets and variables -> Actions do repo).
# -----------------------------------------------------------------------------
# HOSTINGER_FTP_SERVER=ftp.despertarespiral.com
# HOSTINGER_FTP_USERNAME=u123456789.deploy
# HOSTINGER_FTP_PASSWORD=********
# HOSTINGER_FTP_REMOTE_DIR=/public_html/
